#!/usr/bin/env bash
set -euo pipefail

# Always run from the repository root
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Ensure required tools are available
if ! command -v yarn >/dev/null 2>&1; then
  echo "pre-commit: yarn is not installed or not in PATH" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "pre-commit: jq is not installed or not in PATH" >&2
  exit 1
fi

# Ensure package.json exists
if [ ! -f "package.json" ]; then
  echo "pre-commit: package.json not found. Create one (e.g. with 'yarn init -y') before committing." >&2
  exit 1
fi

# Bump the patch version in package.json using Yarn's semver handling, without tags or extra git work
yarn version --patch --no-git-tag-version --no-commit-hooks --non-interactive >/dev/null 2>&1

# Read the new version from package.json
VERSION="$(jq -r '.version' package.json)"

if [ -z "$VERSION" ] || [ "$VERSION" = "null" ]; then
  echo "pre-commit: could not read .version from package.json" >&2
  exit 1
fi

NEW_TOKEN="v${VERSION}"

# Find all tracked .html files in the repo
HTML_FILES="$(git ls-files '*.html' || true)"

if [ -z "$HTML_FILES" ]; then
  echo "pre-commit: no tracked .html files found; skipping HTML version updates" >&2
else
  echo "pre-commit: updating version to ${NEW_TOKEN}"
  # Replace any version-like token such as "v1.0.0" with the new version in all .html files
  for file in $HTML_FILES; do
    if [ -f "$file" ]; then
      # macOS/BSD sed requires an empty string after -i for in-place edits
      sed -E -i '' "s/v[0-9]+\.[0-9]+\.[0-9]+/${NEW_TOKEN}/g" "$file"
    fi
  done
fi

# Stage the updated files so this commit always contains the bumped version
git add package.json $HTML_FILES
